# ============================================================
# POTAL — 환경 변수 템플릿
# cp .env.example .env.local  후 실제 키 입력
# 마지막 업데이트: 2026-02-19
# ============================================================
#
# ⚠️ 새 AI 세션에서 이 파일을 수정하지 마세요!
# ⚠️ 실제 키는 .env.local에만 저장하세요.
#
# 각 호스트명은 Provider 코드의 fallback과 일치해야 합니다.
# Provider 교체 시 여기도 함께 업데이트하세요.
#

# ==========================================
# 1. RapidAPI Master Key
# ==========================================
RAPIDAPI_KEY=your_rapidapi_key_here

# ==========================================
# 2. Provider별 RapidAPI Host
# ==========================================

# ── DOMESTIC (미국) ──
RAPIDAPI_HOST_AMAZON=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_HOST_WALMART=realtime-walmart-data.p.rapidapi.com
RAPIDAPI_HOST_BESTBUY=bestbuy-usa.p.rapidapi.com
RAPIDAPI_HOST_EBAY=real-time-ebay-data.p.rapidapi.com
RAPIDAPI_HOST_TARGET=target-com-shopping-api.p.rapidapi.com

# ── GLOBAL (해외직구) ──
RAPIDAPI_HOST_ALIEXPRESS=aliexpress-data.p.rapidapi.com

# ── 비활성화 ──
# RAPIDAPI_HOST_SHEIN=unofficial-shein.p.rapidapi.com       # API 전멸 → CJ Affiliate API 전환 예정
# RAPIDAPI_HOST_COSTCO=costco-real-time-deals-api-discounts-ratings-dates.p.rapidapi.com  # Deals API만 제공

# ==========================================
# 3. Apify (Temu 전용)
#    ⚠️ Temu는 Apify 사용! RapidAPI 아님!
#    Actor: amit123/temu-products-scraper
# ==========================================
APIFY_API_TOKEN=apify_api_your_token_here

# ==========================================
# 4. OpenAI (AI 기능 필수)
# ==========================================
OPENAI_API_KEY=sk-your_openai_key_here

# ==========================================
# 5. Supabase (인증)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==========================================
# 6. 어필리에이트 코드 (수익화, optional)
# ==========================================
AMAZON_AFFILIATE_TAG=your-amazon-tag-20
TEMU_AFFILIATE_CODE=your_temu_code
EBAY_CAMPAIGN_ID=your_ebay_campaign_id
ALIEXPRESS_APP_KEY=your_ali_app_key
ALIEXPRESS_APP_SECRET=your_ali_app_secret
CJ_PERSONAL_TOKEN=your_cj_token
CJ_PROPERTY_ID=your_cj_property_id
# WALMART_AFFILIATE_ID=your_walmart_id     # US 주소 활성화 후
# BESTBUY_AFFILIATE_ID=your_bestbuy_id     # US 주소 활성화 후
# TARGET_AFFILIATE_ID=your_target_id       # US 주소 활성화 후
# SHEIN_AFFILIATE_ID=your_shein_id         # CJ 승인 후

# ==========================================
# 7. AI HS Code Classification (Phase 5.5)
# ==========================================
# AI 분류 설정 (기본: OpenAI gpt-4o-mini — 저렴하고 분류 작업에 충분)
AI_CLASSIFIER_ENABLED=true
AI_CLASSIFIER_PROVIDER=openai              # 'openai' (기본) 또는 'anthropic'
# Anthropic은 옵션 (필요 시만 설정)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
AI_CLASSIFIER_TIMEOUT_MS=10000             # AI API 타임아웃 (밀리초)
AI_CLASSIFIER_MIN_CONFIDENCE=0.6           # 키워드 매칭 이 이하면 AI 호출
AI_CLASSIFIER_MAX_CACHE_AGE_DAYS=30        # DB 캐시 보존 기간

# ==========================================
# 8. External Tariff API (관세율 외부 API)
# ==========================================
TARIFF_API_ENABLED=true
TARIFF_API_PROVIDER=open-trade             # 프로바이더 선택
TARIFF_API_TIMEOUT_MS=15000
TARIFF_API_CIRCUIT_BREAKER_THRESHOLD=5     # 연속 실패 허용 횟수
TARIFF_API_CIRCUIT_BREAKER_RESET_MS=300000 # 서킷 브레이커 리셋 시간 (5분)
# WTO Tariff Data API (무료, 등록 필요)
WTO_TARIFF_API_KEY=your_wto_api_key_here
# Dutify API (상용, 옵션)
# DUTIFY_API_KEY=your_dutify_key_here

# ==========================================
# 9. Analytics
# ==========================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==========================================
# 10. Paddle Billing (결제)
# ==========================================
PADDLE_API_KEY=pdl_live_apikey_xxxx
PADDLE_WEBHOOK_SECRET=ntfset_xxxx
PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxx
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
PADDLE_PRICE_BASIC_MONTHLY=pri_xxxx
PADDLE_PRICE_BASIC_ANNUAL=pri_xxxx
PADDLE_PRICE_PRO_MONTHLY=pri_xxxx
PADDLE_PRICE_PRO_ANNUAL=pri_xxxx
PADDLE_PRICE_ENTERPRISE_MONTHLY=pri_xxxx
PADDLE_PRICE_ENTERPRISE_ANNUAL=pri_xxxx

# ==========================================
# 11. Customer Success (Crisp Chat)
# ==========================================
NEXT_PUBLIC_CRISP_WEBSITE_ID=your_crisp_website_id

# ==========================================
# 12. App Configuration
# ==========================================
NEXT_PUBLIC_BASE_URL=https://www.potal.app

# ==========================================
# 13. Email Notifications (Resend)
# ==========================================
RESEND_API_KEY=re_your_resend_api_key
MORNING_BRIEF_EMAIL_TO=contact@potal.app
MORNING_BRIEF_EMAIL_FROM=POTAL <onboarding@resend.dev>
