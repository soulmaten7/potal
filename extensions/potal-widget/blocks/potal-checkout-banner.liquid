{% comment %}
  POTAL Checkout Banner
  — Shopify Theme App Extension: Cart/Checkout Page Block

  장바구니 또는 체크아웃 페이지에서 예상 관세/세금 안내를 표시합니다.
  고객이 결제 전에 추가 비용을 알 수 있어 장바구니 이탈률을 낮춥니다.

  "No surprise fees at delivery" 메시지와 함께
  주요 관세/세금 항목을 미리 보여줍니다.
{% endcomment %}

{% if cart.items.size > 0 %}
<div
  id="potal-checkout-banner-{{ block.id }}"
  class="potal-checkout-banner"
  style="
    padding: 16px 20px;
    margin: 12px 0;
    border-radius: 10px;
    border: 1px solid {{ block.settings.border_color }};
    background: {{ block.settings.background_color }};
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  "
>
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.icon_color }}" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 16v-4"/>
      <path d="M12 8h.01"/>
    </svg>
    <span style="font-weight: 600; font-size: 14px; color: {{ block.settings.text_color }};">
      {{ block.settings.heading }}
    </span>
  </div>

  <p style="margin: 0 0 10px 30px; font-size: 13px; color: {{ block.settings.subtext_color }}; line-height: 1.5;">
    {{ block.settings.description }}
  </p>

  <!-- 동적 관세 계산 결과 (JavaScript로 업데이트) -->
  <div id="potal-checkout-estimate-{{ block.id }}" style="
    margin-left: 30px;
    padding: 10px 14px;
    background: rgba(0,0,0,0.03);
    border-radius: 8px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    display: none;
  ">
    Loading estimate...
  </div>

  {% if block.settings.show_powered_by %}
  <div style="margin-top: 8px; margin-left: 30px; font-size: 11px; color: #999;">
    Powered by <a href="https://www.potal.app" target="_blank" rel="noopener" style="color: #F59E0B; text-decoration: none;">POTAL</a>
  </div>
  {% endif %}
</div>

<script>
  (function() {
    var banner = document.getElementById('potal-checkout-banner-{{ block.id }}');
    var estimateEl = document.getElementById('potal-checkout-estimate-{{ block.id }}');
    if (!banner || !estimateEl) return;

    var apiKey = '{{ block.settings.api_key }}';
    var origin = '{{ block.settings.origin_country }}';
    if (!apiKey) return;

    // 장바구니 총액 계산
    var cartTotal = {{ cart.total_price }} / 100; // Shopify는 cents 단위
    var currency = '{{ shop.currency }}';

    // 고객 국가 추측 (Shopify의 localization 활용)
    var customerCountry = '{{ localization.country.iso_code }}' || '';

    if (!customerCountry || customerCountry === '{{ shop.country }}') {
      // 국내 배송이면 관세 불필요
      return;
    }

    estimateEl.style.display = 'block';
    estimateEl.textContent = 'Estimating import duties and taxes...';

    // POTAL API 호출
    fetch('https://www.potal.app/api/v1/calculate', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': apiKey,
      },
      body: JSON.stringify({
        price: cartTotal,
        origin: origin,
        destinationCountry: customerCountry,
        productName: 'Cart items',
      }),
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success && data.data) {
        var d = data.data;
        var parts = [];
        if (d.importDuty > 0) parts.push('Duty: $' + d.importDuty.toFixed(2));
        if (d.vat > 0) parts.push((d.vatLabel || 'Tax') + ': $' + d.vat.toFixed(2));
        if (d.mpf > 0) parts.push('Fees: $' + d.mpf.toFixed(2));

        if (parts.length > 0) {
          estimateEl.innerHTML = '<strong>Estimated additional costs:</strong> ' + parts.join(' + ') +
            ' = <strong style="color: #F59E0B;">$' + (d.totalLandedCost - d.productPrice - d.shippingCost).toFixed(2) + '</strong>';
        } else if (d.deMinimisApplied) {
          estimateEl.innerHTML = '✅ <strong>No import duties!</strong> Your order qualifies for duty-free import.';
        } else {
          estimateEl.innerHTML = '✅ No additional import costs estimated.';
        }
      }
    })
    .catch(function() {
      estimateEl.style.display = 'none';
    });
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "POTAL Import Cost Banner",
  "target": "section",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "text",
      "id": "api_key",
      "label": "POTAL API Key",
      "info": "Your POTAL API key. Get it from [POTAL Dashboard](https://www.potal.app/dashboard)."
    },
    {
      "type": "select",
      "id": "origin_country",
      "label": "Shipping Origin",
      "default": "CN",
      "options": [
        { "value": "CN", "label": "China" },
        { "value": "US", "label": "United States" },
        { "value": "GB", "label": "United Kingdom" },
        { "value": "DE", "label": "Germany" },
        { "value": "JP", "label": "Japan" },
        { "value": "KR", "label": "South Korea" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "International Shipping Notice"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Your order may be subject to import duties and taxes upon arrival. We calculate these upfront so there are no surprises."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF7ED"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#FED7AA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1F2937"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#F59E0B"
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show 'Powered by POTAL'",
      "default": true
    }
  ]
}
{% endschema %}
